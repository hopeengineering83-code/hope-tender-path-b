generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:/tmp/app.db"
}

model User {
  id           String     @id @default(uuid())
  name         String?
  email        String     @unique
  passwordHash String
  role         String     @default("user")
  company      Company?
  tenders      Tender[]
  documents    Document[]
}

model Company {
  id          String  @id @default(uuid())
  name        String
  description String?
  website     String?
  address     String?
  phone       String?
  email       String?
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
}

model Tender {
  id           String     @id @default(uuid())
  title        String
  description  String?
  reference    String?
  category     String     @default("General")
  budget       Float?
  currency     String     @default("USD")
  deadline     String?
  status       String     @default("draft")
  requirements String?
  proposal     String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  documents    Document[]
}

model Document {
  id        String   @id @default(uuid())
  name      String
  size      Int
  mimeType  String
  tenderId  String?
  tender    Tender?  @relation(fields: [tenderId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
