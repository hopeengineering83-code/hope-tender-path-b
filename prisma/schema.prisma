generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:/tmp/app.db"
}

model User {
  id           String    @id @default(uuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         String    @default("user")
  companies    Company[]
}

model Company {
  id          String  @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User    @relation(fields: [userId], references: [id])
}
