generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:/tmp/app.db"
}

model User {
  id           String      @id @default(uuid())
  name         String?
  email        String      @unique
  passwordHash String
  role         String      @default("PROPOSAL_MANAGER")
  company      Company?
  sessions     Session[]
  tenders      Tender[]
  auditLogs    AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id                String                    @id @default(uuid())
  name              String
  legalName         String?
  description       String?
  website           String?
  address           String?
  phone             String?
  email             String?
  country           String?
  serviceLines      String                    @default("[]")
  sectors           String                    @default("[]")
  profileSummary    String?
  knowledgeMode     String                    @default("PROFILE_FIRST")
  setupCompletedAt  DateTime?
  userId            String                    @unique
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  experts           Expert[]
  projects          Project[]
  documents         CompanyDocument[]
  assets            CompanyAsset[]
  legalRecords      LegalRecord[]
  financialRecords  FinancialRecord[]
  complianceRecords CompanyComplianceRecord[]
  settings          AppSettings?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
}

model AppSettings {
  id                    String   @id @default(uuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultCurrency       String   @default("USD")
  aiStrictMode          Boolean  @default(true)
  allowBrandingDefault  Boolean  @default(true)
  allowSignatureDefault Boolean  @default(true)
  allowStampDefault     Boolean  @default(true)
  exportFormat          String   @default("DOCX")
  pageNumbering         Boolean  @default(true)
  includeTableOfContents Boolean @default(false)
  language              String   @default("en")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model CompanyDocument {
  id               String   @id @default(uuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fileName         String
  originalFileName String
  mimeType         String
  size             Int
  storagePath      String   @default("")
  fileContent      String?
  category         String   @default("OTHER")
  extractedText    String?
  metadata         String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompanyAsset {
  id               String   @id @default(uuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetType        String
  fileName         String
  originalFileName String
  mimeType         String
  size             Int
  storagePath      String   @default("")
  fileContent      String?
  isActive         Boolean  @default(true)
  metadata         String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Expert {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName        String
  title           String?
  email           String?
  phone           String?
  yearsExperience Int?
  disciplines     String              @default("[]")
  sectors         String              @default("[]")
  certifications  String              @default("[]")
  profile         String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenderMatches   TenderExpertMatch[]
}

model Project {
  id            String               @id @default(uuid())
  companyId     String
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  clientName    String?
  country       String?
  sector        String?
  serviceAreas  String               @default("[]")
  summary       String?
  contractValue Float?
  currency      String?
  startDate     DateTime?
  endDate       DateTime?
  evidences     ProjectEvidence[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenderMatches TenderProjectMatch[]
}

model ProjectEvidence {
  id               String   @id @default(uuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  evidenceType     String
  description      String?
  fileName         String?
  storagePath      String?
  extractedText    String?
  metadata         String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LegalRecord {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recordType      String
  title           String
  authority       String?
  referenceNumber String?
  issueDate       DateTime?
  expiryDate      DateTime?
  status          String    @default("ACTIVE")
  metadata        String    @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model FinancialRecord {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear Int
  recordType String
  currency  String?  @default("USD")
  amount    Float?
  notes     String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyComplianceRecord {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  complianceType  String
  title           String
  status          String    @default("ACTIVE")
  evidenceSummary String?
  referenceNumber String?
  expiryDate      DateTime?
  metadata        String    @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Tender {
  id                    String               @id @default(uuid())
  title                 String
  description           String?
  reference             String?
  clientName            String?
  category              String               @default("General")
  country               String?
  budget                Float?
  currency              String               @default("USD")
  deadline              DateTime?
  submissionMethod      String?
  submissionAddress     String?
  status                String               @default("DRAFT")
  stage                 String               @default("TENDER_INTAKE")
  intakeSummary         String?
  analysisSummary       String?
  evaluationMethodology String?
  pageLimit             Int?
  exactFileOrder        String               @default("[]")
  exactFileNaming       String               @default("[]")
  readinessScore        Float                @default(0)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  userId                String
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  files                 TenderFile[]
  requirements          TenderRequirement[]
  expertMatches         TenderExpertMatch[]
  projectMatches        TenderProjectMatch[]
  complianceGaps        ComplianceGap[]
  complianceMatrix      ComplianceMatrix[]
  generatedDocuments    GeneratedDocument[]
  exportPackages        ExportPackage[]
}

model TenderFile {
  id               String   @id @default(uuid())
  tenderId         String
  tender           Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  fileName         String
  originalFileName String
  mimeType         String
  size             Int
  storagePath      String   @default("")
  fileContent      String?
  classification   String?
  extractedText    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TenderRequirement {
  id                   String             @id @default(uuid())
  tenderId             String
  tender               Tender             @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  code                 String?
  title                String
  description          String
  requirementType      String
  priority             String
  sectionReference     String?
  requiredQuantity     Int?
  pageLimit            Int?
  exactFileName        String?
  exactOrder           Int?
  restrictions         String?
  isResolved           Boolean            @default(false)
  complianceMatrixRows ComplianceMatrix[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model ComplianceMatrix {
  id                String             @id @default(uuid())
  tenderId          String
  tender            Tender             @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  requirementId     String?
  requirement       TenderRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  evidenceType      String
  evidenceSource    String
  evidenceReference String?
  supportLevel      String             @default("PARTIAL")
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model TenderExpertMatch {
  id         String   @id @default(uuid())
  tenderId   String
  tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  expertId   String
  expert     Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  score      Float
  rationale  String?
  isSelected Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TenderProjectMatch {
  id         String   @id @default(uuid())
  tenderId   String
  tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  score      Float
  rationale  String?
  isSelected Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ComplianceGap {
  id             String   @id @default(uuid())
  tenderId       String
  tender         Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  requirementId  String?
  severity       String
  title          String
  description    String
  mitigationPlan String?
  isResolved     Boolean  @default(false)
  resolvedNote   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GeneratedDocument {
  id               String    @id @default(uuid())
  tenderId         String
  tender           Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  name             String
  documentType     String
  format           String    @default("DOCX")
  storagePath      String?
  exactFileName    String?
  exactOrder       Int?
  contentSummary   String?
  fileContent      String?
  validationStatus String    @default("PENDING")
  generationStatus String    @default("PLANNED")
  reviewStatus     String    @default("PENDING")
  reviewNotes      String?
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ExportPackage {
  id            String   @id @default(uuid())
  tenderId      String
  tender        Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  status        String   @default("PREPARING")
  fileList      String   @default("[]")
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  entityType  String?
  entityId    String?
  description String
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
}
