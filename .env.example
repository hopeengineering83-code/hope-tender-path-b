# ── Database (PostgreSQL required — SQLite not supported in production) ────────
# Use Neon, Supabase, Railway, or any PostgreSQL provider.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ── Session security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-this-with-a-64-character-random-hex-string"

# ── AI (required for extraction + proposal generation) ───────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ── Optional ──────────────────────────────────────────────────────────────────
# STORAGE_ROOT="./.storage"
# BLOB_READ_WRITE_TOKEN=""
